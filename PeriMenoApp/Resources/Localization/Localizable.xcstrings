    "settings.debug.resetConfirm.message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يزيل هذا العينات المحلية وإدخالات التتبع من هذا الجهاز."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies entfernt lokale Beispiel- und Tracking-Einträge von diesem Gerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes local sample and tracking entries from this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina las entradas de muestra y seguimiento locales de este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime les exemples locaux et les entrées de suivi de cet appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह इस डिवाइस से स्थानीय नमूना और ट्रैकिंग प्रविष्टियाँ हटाता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini menghapus contoh lokal dan entri pelacakan dari perangkat ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuove i dati di esempio e monitoraggio locali da questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末からローカルのサンプル記録と追跡記録を削除します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서 로컬 샘플 및 추적 기록을 삭제합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso remove as entradas locais de amostra e acompanhamento deste dispositivo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบข้อมูลตัวอย่างและรายการติดตามในเครื่องจากอุปกรณ์นี้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, yerel örnek ve takip kayıtlarını bu cihazdan kaldırır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这会从本设备移除本地示例和追踪记录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這會從本裝置移除本機範例和追蹤記錄。"
          }
        }
      }
    },
