    "reports.summary.lowData": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "البيانات محدودة: راجعي بحذر واستمري في التتبع لنمط أوضح."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Begrenzte Daten: Vorsichtig prüfen und weiter protokollieren, um ein klareres Muster zu sehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Limited data: review cautiously and continue tracking for a clearer pattern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Datos limitados: revisa con cautela y sigue registrando para ver un patrón más claro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Données limitées : examinez avec prudence et continuez le suivi pour une tendance plus claire."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डेटा सीमित है: सावधानी से देखें और स्पष्ट पैटर्न के लिए ट्रैकिंग जारी रखें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Data terbatas: tinjau dengan hati-hati dan lanjutkan pelacakan untuk pola yang lebih jelas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dati limitati: valuta con cautela e continua a monitorare per uno schema più chiaro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データが限られています。慎重に確認し、より明確な傾向のために記録を続けてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터가 제한적입니다. 신중히 검토하고 더 명확한 패턴을 위해 계속 기록하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dados limitados: revise com cautela e continue acompanhando para um padrão mais claro."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ข้อมูลจำกัด: โปรดตรวจอย่างระมัดระวังและติดตามต่อเพื่อเห็นรูปแบบชัดขึ้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sınırlı veri: Dikkatle inceleyin ve daha net bir örüntü için takip etmeye devam edin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据有限：请谨慎查看，并继续追踪以获得更清晰趋势。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "資料有限：請謹慎查看，並繼續追蹤以獲得更清楚趨勢。"
          }
        }
      }
    },
