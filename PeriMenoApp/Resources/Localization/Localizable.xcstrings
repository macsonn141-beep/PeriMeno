    "home.appointment.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حضّري أسئلة وملخصات موجزة قبل زيارتك القادمة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bereite kurze Fragen und Zusammenfassungen vor deinem nächsten Besuch vor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepare concise questions and summaries before your next visit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepara preguntas y resúmenes breves antes de tu próxima visita."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Préparez des questions et résumés concis avant votre prochaine visite."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अगली विज़िट से पहले संक्षिप्त प्रश्न और सारांश तैयार करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Siapkan pertanyaan dan ringkasan singkat sebelum kunjungan berikutnya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepara domande e riepiloghi brevi prima della prossima visita."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次回の受診前に、短い質問と要約を準備します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다음 방문 전에 간단한 질문과 요약을 준비하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepare perguntas e resumos breves antes da próxima consulta."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เตรียมคำถามและสรุปสั้นๆ ก่อนการพบแพทย์ครั้งต่อไป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir sonraki ziyaretinizden önce kısa sorular ve özetler hazırlayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次就诊前，准备简洁的问题和摘要。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下次就診前，準備簡潔的問題和摘要。"
          }
        }
      }
    },
