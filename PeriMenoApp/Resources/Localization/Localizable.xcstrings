    "settings.privacy.summary": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يخزن PeriMeno البيانات محليًا ولا يتضمن إعلانات أو تحليلات طرف ثالث."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno speichert Daten lokal und enthält keine Werbung oder Drittanbieter-Analytics."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno stores data locally and does not include ads or third-party analytics."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno guarda los datos localmente y no incluye anuncios ni analíticas de terceros."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno stocke les données localement et n’inclut ni publicité ni analytics tiers."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno डेटा स्थानीय रूप से सहेजता है और विज्ञापन या थर्ड-पार्टी एनालिटिक्स शामिल नहीं करता।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno menyimpan data secara lokal dan tidak menyertakan iklan atau analitik pihak ketiga."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno archivia i dati localmente e non include pubblicità né analisi di terze parti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMenoはデータをローカルに保存し、広告や第三者分析を含みません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno는 데이터를 로컬에 저장하며 광고나 타사 분석을 포함하지 않습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno armazena dados localmente e não inclui anúncios nem analytics de terceiros."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno เก็บข้อมูลในเครื่องและไม่มีโฆษณาหรือการวิเคราะห์จากบุคคลที่สาม"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno verileri yerel olarak saklar ve reklam ya da üçüncü taraf analiz içermez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno 将数据存储在本机，不包含广告或第三方分析。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno 将数据存储在本机，不包含广告或第三方分析。"
          }
        }
      }
    },
