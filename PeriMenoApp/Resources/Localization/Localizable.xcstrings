    "privacy.security.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن إضافة قفل Face ID اختياري دون تغيير نموذج البيانات المحلي أولًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optionale Face-ID-Sperre kann hinzugefügt werden, ohne das lokale Datenmodell zu ändern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional Face ID lock can be added without changing the local-first data model."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El bloqueo opcional con Face ID se puede añadir sin cambiar el modelo de datos local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le verrouillage Face ID facultatif peut être ajouté sans changer le modèle de données local."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय-प्रथम डेटा मॉडल बदले बिना वैकल्पिक Face ID लॉक जोड़ा जा सकता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunci Face ID opsional dapat ditambahkan tanpa mengubah model data lokal-first."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il blocco Face ID opzionale può essere aggiunto senza cambiare il modello dati locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカル優先のデータモデルを変えずに、任意のFace IDロックを追加できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 우선 데이터 모델을 바꾸지 않고 선택적 Face ID 잠금을 추가할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O bloqueio opcional por Face ID pode ser adicionado sem mudar o modelo de dados local."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สามารถเพิ่มล็อก Face ID ได้โดยไม่เปลี่ยนโมเดลข้อมูลแบบเก็บในเครื่องก่อน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İsteğe bağlı Face ID kilidi, yerel öncelikli veri modeli değişmeden eklenebilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可添加 Face ID 锁定，同时不改变本地优先的数据模式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
