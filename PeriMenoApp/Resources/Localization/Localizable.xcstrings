    "paywall.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يفتح المميز رؤى أعمق وسجلًا غير محدود وتقارير كاملة وقوالب متقدمة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium schaltet tiefere Einblicke, unbegrenzten Verlauf, vollständige Berichte und erweiterte Vorlagen frei."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium unlocks deeper insights, unlimited history, full reports, and advanced templates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium desbloquea análisis más profundos, historial ilimitado, informes completos y plantillas avanzadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium débloque des analyses plus poussées, un historique illimité, des rapports complets et des modèles avancés."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रीमियम गहरी इनसाइट, असीमित इतिहास, पूर्ण रिपोर्ट और उन्नत टेम्पलेट अनलॉक करता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium membuka insight lebih dalam, riwayat tanpa batas, laporan lengkap, dan template lanjutan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium sblocca insight più profondi, cronologia illimitata, report completi e modelli avanzati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレミアムでは、より深い洞察、無制限の履歴、完全なレポート、高度なテンプレートを利用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프리미엄은 더 깊은 인사이트, 무제한 기록, 전체 보고서, 고급 템플릿을 제공합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium desbloqueia insights mais profundos, histórico ilimitado, relatórios completos e modelos avançados."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "พรีเมียมปลดล็อกข้อมูลเชิงลึก ประวัติไม่จำกัด รายงานเต็ม และเทมเพลตขั้นสูง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium daha derin içgörüler, sınırsız geçmiş, tam raporlar ve gelişmiş şablonlar açar."
          }
        },
        "zh-Hans": {
