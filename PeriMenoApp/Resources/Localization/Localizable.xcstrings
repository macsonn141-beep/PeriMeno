    "reports.pdf.lowData": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "البيانات محدودة: يمكن إنشاء هذا التقرير، لكنه قد يكون أكثر فائدة بعد 3 سجلات على الأقل."
          }
        },
        "de": {
          "stringUnit": {
