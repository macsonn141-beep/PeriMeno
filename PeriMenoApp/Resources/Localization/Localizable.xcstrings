    "home.empty.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد سجلات بعد. أضيفي أعراض اليوم وتقييماته وملاحظاته لبدء رؤية الأنماط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Protokolle. Füge heutige Symptome, Bewertungen und Notizen hinzu, um Muster zu erkennen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No logs yet. Add today's symptoms, ratings, and notes to start seeing patterns."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay registros. Añade los síntomas, puntuaciones y notas de hoy para empezar a ver patrones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun journal pour le moment. Ajoutez les symptômes, évaluations et notes du jour pour commencer à voir des tendances."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी कोई लॉग नहीं। पैटर्न देखने के लिए आज के लक्षण, रेटिंग और नोट्स जोड़ें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada catatan. Tambahkan gejala, penilaian, dan catatan hari ini untuk mulai melihat pola."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessun diario. Aggiungi sintomi, valutazioni e note di oggi per iniziare a vedere schemi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ記録がありません。今日の症状、評価、メモを追加すると傾向が見え始めます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 기록이 없습니다. 오늘의 증상, 평점, 메모를 추가하면 패턴을 볼 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há registros. Adicione os sintomas, pontuações e notas de hoje para começar a ver padrões."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังไม่มีบันทึก เพิ่มอาการ คะแนน และโน้ตของวันนี้เพื่อเริ่มเห็นรูปแบบ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Henüz kayıt yok. Örüntüleri görmeye başlamak için bugünün belirtilerini, puanlarını ve notlarını ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有记录。添加今天的症状、评分和备注后，就可以开始看到趋势。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "还没有记录。添加今天的症状、评分和备注后，就可以开始看到趋势。"
          }
        }
      }
    },
