    "paywall.localTestingFallback": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "منتجات StoreKit غير متاحة من Xcode الآن. تم تفعيل بديل الشراء المحلي للتصحيح لاختبار Simulator."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "StoreKit-Produkte sind derzeit nicht aus Xcode verfügbar. Der lokale Debug-Kauf-Fallback ist für Simulator-Tests aktiviert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "StoreKit products are not available from Xcode right now. Debug local purchase fallback is enabled for Simulator testing."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los productos de StoreKit no están disponibles desde Xcode ahora. La alternativa local de compra de depuración está activada para pruebas en Simulator."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les produits StoreKit ne sont pas disponibles depuis Xcode actuellement. Le mode de repli d’achat local de debug est activé pour les tests dans Simulator."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "StoreKit उत्पाद अभी Xcode से उपलब्ध नहीं हैं। Simulator परीक्षण के लिए debug local purchase fallback सक्षम है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Produk StoreKit tidak tersedia dari Xcode saat ini. Fallback pembelian lokal debug diaktifkan untuk pengujian Simulator."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I prodotti StoreKit non sono disponibili da Xcode al momento. Il fallback di acquisto locale debug è attivo per i test nel Simulator."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在XcodeからStoreKit商品を利用できません。Simulatorテスト用にデバッグ用ローカル購入フォールバックが有効です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 Xcode에서 StoreKit 제품을 사용할 수 없습니다. Simulator 테스트를 위해 디버그 로컬 구매 대체 모드가 활성화되었습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os produtos do StoreKit não estão disponíveis pelo Xcode agora. A alternativa local de compra de debug está ativada para testes no Simulator."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตอนนี้สินค้า StoreKit ไม่พร้อมใช้งานจาก Xcode เปิดใช้ fallback การซื้อในเครื่องสำหรับทดสอบ Simulator แล้ว"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "StoreKit ürünleri şu anda Xcode’dan kullanılamıyor. Simulator testi için debug yerel satın alma yedeği etkin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前 Xcode 没有提供 StoreKit 产品。模拟器测试已启用调试本地购买备用模式。"
          }
        },
        "zh-Hant": {
