    "entry.delete.alert.message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتم إزالة هذا الإدخال وتفاصيل أعراضه من السجل المحلي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Eintrag und seine Symptomdetails werden aus dem lokalen Verlauf entfernt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This entry and its symptom details will be removed from local history."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta entrada y sus detalles de síntomas se eliminarán del historial local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette entrée et les détails de ses symptômes seront supprimés de l’historique local."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह प्रविष्टि और इसके लक्षण विवरण स्थानीय इतिहास से हटाए जाएँगे।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Entri ini dan detail gejalanya akan dihapus dari riwayat lokal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa voce e i dettagli dei sintomi saranno rimossi dalla cronologia locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この記録と症状の詳細はローカル履歴から削除されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기록과 증상 세부 정보가 로컬 기록에서 삭제됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta entrada e seus detalhes de sintomas serão removidos do histórico local."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รายการนี้และรายละเอียดอาการจะถูกลบออกจากประวัติในเครื่อง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu kayıt ve belirti ayrıntıları yerel geçmişten kaldırılacak."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此记录及其症状详情将从本地历史中删除。"
          }
