        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Low sleep and high brain fog appeared together in entries:"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Poco sueño y mucha niebla mental aparecieron juntos en estas entradas:"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un sommeil faible et un brouillard mental élevé sont apparus ensemble dans les entrées :"
