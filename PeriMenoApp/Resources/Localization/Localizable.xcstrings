    "onboarding.notifications.detail": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن إضافة التذكيرات لاحقًا دون تغيير نموذج الخصوصية المحلي أولًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erinnerungen können später hinzugefügt werden, ohne das lokale Datenschutzmodell zu ändern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reminders can be added later without changing the local-first privacy model."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los recordatorios se pueden añadir más tarde sin cambiar el modelo de privacidad local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les rappels peuvent être ajoutés plus tard sans changer le modèle de confidentialité local."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्थानीय-प्रथम गोपनीयता मॉडल बदले बिना रिमाइंडर बाद में जोड़े जा सकते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pengingat dapat ditambahkan nanti tanpa mengubah model privasi lokal-first."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I promemoria possono essere aggiunti più tardi senza cambiare il modello privacy locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカル優先のプライバシーモデルを変えずに、後でリマインダーを追加できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "로컬 우선 개인정보 모델을 바꾸지 않고 나중에 알림을 추가할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Lembretes podem ser adicionados depois sem alterar o modelo de privacidade local."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สามารถเพิ่มการเตือนภายหลังได้โดยไม่เปลี่ยนโมเดลความเป็นส่วนตัวแบบเก็บในเครื่องก่อน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hatırlatıcılar, yerel öncelikli gizlilik modeli değişmeden daha sonra eklenebilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "之后可以添加提醒，同时不改变本地优先的隐私模式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "之后可以添加提醒，同时不改变本地优先的隐私模式。"
          }
        }
      }
    },
