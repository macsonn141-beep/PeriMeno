    "correlation.disclaimer": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ملخصات الارتباط تقديرية ويجب أن تدعم محادثات الطبيب لا أن تستبدلها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Korrelationszusammenfassungen sind heuristisch und sollen Gespräche mit Fachpersonen unterstützen, nicht ersetzen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Correlation summaries are heuristic and should support, not replace, clinician conversations."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los resúmenes de correlación son orientativos y deben apoyar, no reemplazar, las conversaciones con profesionales clínicos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les résumés de corrélation sont heuristiques et doivent soutenir, non remplacer, les échanges avec les cliniciens."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सहसंबंध सारांश अनुमानात्मक हैं और चिकित्सक से बातचीत का समर्थन करते हैं, उसका विकल्प नहीं हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ringkasan korelasi bersifat heuristik dan mendukung, bukan menggantikan, percakapan dengan klinisi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I riepiloghi di correlazione sono euristici e devono supportare, non sostituire, il dialogo con i clinici."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "相関の要約は目安であり、医療者との相談を支援するもので、代替するものではありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상관 요약은 참고용이며 의료진과의 상담을 대체하지 않고 보조해야 합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os resumos de correlação são heurísticos e devem apoiar, não substituir, conversas com profissionais de saúde."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สรุปความสัมพันธ์เป็นเพียงแนวทางและควรช่วยสนับสนุน ไม่ใช่แทนที่การปรึกษาแพทย์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Korelasyon özetleri sezgiseldir ve klinisyen görüşmelerini desteklemeli, onların yerini almamalıdır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相关性摘要只是启发式参考，用来辅助而不是替代与医生的沟通。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "相關性摘要只是啟發式參考，用來輔助而不是取代與醫師的溝通。"
          }
        }
      }
    },
