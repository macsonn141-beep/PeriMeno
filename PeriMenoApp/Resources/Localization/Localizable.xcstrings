    "onboarding.brainFog.detail": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدمي عناصر تحكم أكبر وخطوات أقل في الأيام الصعبة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nutze an schwierigen Tagen größere Bedienelemente und weniger Schritte."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use larger controls and fewer steps on difficult days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa controles más grandes y menos pasos en días difíciles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez des contrôles plus grands et moins d’étapes les jours difficiles."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कठिन दिनों में बड़े नियंत्रण और कम चरणों का उपयोग करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan kontrol lebih besar dan langkah lebih sedikit pada hari sulit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa controlli più grandi e meno passaggi nei giorni difficili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "つらい日は大きな操作ボタンと少ない手順で使えます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "힘든 날에는 더 큰 컨트롤과 더 적은 단계로 사용하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use controles maiores e menos etapas em dias difíceis."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ใช้ปุ่มที่ใหญ่ขึ้นและขั้นตอนน้อยลงในวันที่ลำบาก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zor günlerde daha büyük kontroller ve daha az adım kullanın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在困难的日子使用更大的控件和更少步骤。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在困難的日子使用更大的控制項和更少步驟。"
          }
        }
      }
    },
