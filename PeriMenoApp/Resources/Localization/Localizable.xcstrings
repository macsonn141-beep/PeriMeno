    "onboarding.subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتبعي الأعراض ولاحظي الأنماط وحضّري للمواعيد بخصوصية على هذا الجهاز."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tracke Symptome, erkenne Muster und bereite Termine privat auf diesem Gerät vor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track symptoms, notice patterns, and prepare for appointments privately on this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra síntomas, observa patrones y prepara citas de forma privada en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez les symptômes, repérez les tendances et préparez vos rendez-vous en privé sur cet appareil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस डिवाइस पर निजी रूप से लक्षण ट्रैक करें, पैटर्न देखें और अपॉइंटमेंट की तैयारी करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lacak gejala, lihat pola, dan siapkan janji secara pribadi di perangkat ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitora sintomi, nota schemi e prepara visite in privato su questo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この端末上でプライベートに症状を記録し、傾向を見つけ、受診準備ができます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서 비공개로 증상을 기록하고 패턴을 확인하며 진료를 준비하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre sintomas, observe padrões e prepare consultas com privacidade neste dispositivo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ติดตามอาการ เห็นรูปแบบ และเตรียมนัดหมายอย่างเป็นส่วนตัวบนอุปกรณ์นี้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Belirtileri takip edin, örüntüleri fark edin ve randevulara bu cihazda gizli şekilde hazırlanın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在本设备上私密记录症状、发现趋势并准备就诊。"
