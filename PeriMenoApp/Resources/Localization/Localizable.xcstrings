    "home.premium.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتحي رؤى أعمق وتقارير وأدوات متقدمة لضباب الدماغ مع إبقاء البيانات محلية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte tiefere Einblicke, Berichte und erweiterte Brain-Fog-Tools frei, während die Daten lokal bleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock deeper insights, reports, and advanced Brain Fog tools while keeping data local."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea análisis más profundos, informes y herramientas avanzadas de niebla mental manteniendo los datos locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Débloquez des analyses plus détaillées, des rapports et des outils avancés de brouillard mental tout en gardant les données locales."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डेटा स्थानीय रखते हुए गहरी इनसाइट, रिपोर्ट और उन्नत ब्रेन फ़ॉग टूल अनलॉक करें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka insight lebih dalam, laporan, dan alat Brain Fog lanjutan sambil menjaga data tetap lokal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca insight più approfonditi, report e strumenti avanzati per la nebbia mentale mantenendo i dati locali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データをローカルに保ったまま、より深い洞察、レポート、高度なブレインフォグツールを利用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터를 로컬에 유지하면서 더 깊은 인사이트, 보고서, 고급 브레인 포그 도구를 잠금 해제하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie insights mais profundos, relatórios e ferramentas avançadas de névoa mental mantendo os dados locais."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปลดล็อกข้อมูลเชิงลึก รายงาน และเครื่องมือ Brain Fog ขั้นสูงโดยเก็บข้อมูลไว้ในเครื่อง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verileri yerel tutarken daha derin içgörüler, raporlar ve gelişmiş beyin sisi araçlarının kilidini açın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在数据保留本机的同时，解锁更深入的洞察、报告和高级脑雾工具。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在資料保留本機的同時，解鎖更深入的洞察、報告和進階腦霧工具。"
          }
        }
      }
    },
