          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Limited data: this report can be generated, but it may be more useful after at least 3 logs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Datos limitados: este informe puede generarse, pero será más útil después de al menos 3 registros."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Données limitées : ce rapport peut être généré, mais sera plus utile après au moins 3 journaux."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डेटा सीमित है: यह रिपोर्ट बन सकती है, लेकिन कम से कम 3 लॉग के बाद अधिक उपयोगी होगी।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Data terbatas: laporan ini dapat dibuat, tetapi mungkin lebih berguna setelah minimal 3 catatan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dati limitati: questo report può essere generato, ma sarà più utile dopo almeno 3 registri."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データが少なめです。このレポートは生成できますが、少なくとも3件の記録後の方が役立ちます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데이터가 제한적입니다. 보고서는 생성할 수 있지만 최소 3개 기록 후 더 유용할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dados limitados: este relatório pode ser gerado, mas será mais útil após pelo menos 3 registros."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ข้อมูลจำกัด: สร้างรายงานได้ แต่อาจมีประโยชน์มากขึ้นหลังมีอย่างน้อย 3 บันทึก"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sınırlı veri: Bu rapor oluşturulabilir, ancak en az 3 kayıttan sonra daha yararlı olabilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据有限：可以生成报告，但至少 3 条记录后会更有用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
