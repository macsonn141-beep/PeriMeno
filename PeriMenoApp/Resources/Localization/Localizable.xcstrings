    "stageHint.placeholder": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستظهر تلميحات المرحلة بعد إضافة سياق ملف شخصي أكثر."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Phasenhinweise erscheinen, wenn mehr Profilkontext vorhanden ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stage hints will appear after more profile context."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las pistas de etapa aparecerán cuando haya más contexto de perfil."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les indications d’étape apparaîtront avec plus de contexte de profil."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अधिक प्रोफ़ाइल संदर्भ के बाद चरण संकेत दिखेंगे।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Petunjuk tahap akan muncul setelah lebih banyak konteks profil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I suggerimenti di fase appariranno con più contesto del profilo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロフィール情報が増えるとステージのヒントが表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프로필 맥락이 더 추가되면 단계 힌트가 표시됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dicas de fase aparecerão após mais contexto de perfil."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คำแนะนำระยะจะแสดงเมื่อมีบริบทโปรไฟล์มากขึ้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aşama ipuçları daha fazla profil bağlamından sonra görünür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加更多个人背景后会显示阶段提示。"
