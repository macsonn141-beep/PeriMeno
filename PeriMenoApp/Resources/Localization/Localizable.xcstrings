    "log.medication.empty": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضيفي ملف دواء أولًا لتمييزه كمتناول هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lege zuerst ein Medikamentenprofil an, um es hier als eingenommen zu markieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a medication profile first to mark it as taken here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade primero un perfil de medicación para marcarlo como tomado aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez d’abord un profil de médicament pour le marquer comme pris ici."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यहाँ लिया हुआ चिह्नित करने के लिए पहले दवा प्रोफ़ाइल जोड़ें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan profil obat terlebih dahulu untuk menandainya sudah diminum di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi prima un profilo farmaco per segnarlo come assunto qui."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここで服用済みにするには、先に薬のプロフィールを追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에서 복용으로 표시하려면 먼저 복약 프로필을 추가하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione primeiro um perfil de medicação para marcá-la como tomada aqui."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่มโปรไฟล์ยาก่อนเพื่อทำเครื่องหมายว่ากินแล้วที่นี่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Burada alınmış olarak işaretlemek için önce bir ilaç profili ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先添加用药资料，才能在这里标记已服用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請先加入用藥資料，才能在這裡標記已服用。"
          }
        }
      }
    },
