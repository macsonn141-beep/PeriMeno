    "home.hero.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تتبعي الأعراض وضباب الدماغ والمزاج والنوم والأنماط بخصوصية، ثم حوّلي ملاحظاتك إلى تقارير للطبيب."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolge Symptome, Brain Fog, Stimmung, Schlaf und Muster privat und erstelle daraus arztgerechte Berichte."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track symptoms, brain fog, mood, sleep, and patterns privately, then turn your notes into doctor-ready reports."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra síntomas, niebla mental, ánimo, sueño y patrones en privado, y convierte tus notas en informes para el médico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez vos symptômes, le brouillard mental, l’humeur, le sommeil et les tendances en privé, puis créez des rapports prêts pour le médecin."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लक्षण, ब्रेन फॉग, मूड, नींद और पैटर्न को निजी रूप से ट्रैक करें और नोट्स को डॉक्टर के लिए रिपोर्ट में बदलें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Catat gejala, brain fog, suasana hati, tidur, dan pola secara privat, lalu ubah catatan menjadi laporan untuk dokter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitora sintomi, nebbia mentale, umore, sonno e schemi in privato e crea report per il medico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "症状、ブレインフォグ、気分、睡眠、傾向をプライベートに記録し、医師に見せやすいレポートを作成できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "증상, 브레인 포그, 기분, 수면, 패턴을 비공개로 기록하고 진료용 보고서로 정리하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre sintomas, névoa mental, humor, sono e padrões com privacidade, e transforme suas notas em relatórios para o médico."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกอาการ สมองล้า อารมณ์ การนอน และรูปแบบต่าง ๆ อย่างเป็นส่วนตัว แล้วสร้างรายงานสำหรับแพทย์ได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Belirtileri, beyin sisini, ruh halini, uykuyu ve örüntüleri gizli takip edin; notlarınızı doktor raporuna dönüştürün."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
