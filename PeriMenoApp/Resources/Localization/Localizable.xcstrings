          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "症状、周期、薬、睡眠、気分、エネルギー、メモを記録します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
