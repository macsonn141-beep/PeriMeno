    "onboarding.baseline.detail": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن أن تساعد التفاصيل الأساسية الاختيارية في إبقاء سياق التتبع ثابتًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optionale Basisdetails können helfen, deinen Tracking-Kontext konsistent zu halten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional baseline details can help keep your tracking context consistent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos base opcionales pueden ayudar a mantener el contexto de seguimiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des détails de base facultatifs peuvent aider à garder un contexte de suivi cohérent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "वैकल्पिक बेसलाइन विवरण ट्रैकिंग संदर्भ को स्थिर रखने में मदद कर सकते हैं।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Detail dasar opsional dapat membantu menjaga konteks pelacakan tetap konsisten."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dettagli di base opzionali aiutano a mantenere coerente il contesto del monitoraggio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意の基本情報は、記録の背景を一貫して保つ助けになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택적 기본 정보는 기록 맥락을 일관되게 유지하는 데 도움이 됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Detalhes básicos opcionais ajudam a manter o contexto do acompanhamento."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รายละเอียดพื้นฐานเพิ่มเติมช่วยให้บริบทการติดตามสม่ำเสมอ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İsteğe bağlı başlangıç ayrıntıları takip bağlamınızı tutarlı tutmaya yardımcı olabilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可选的基础信息能帮助保持追踪背景一致。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "可選的基礎資訊能幫助保持追蹤背景一致。"
          }
        }
      }
    },
    "onboarding.baseline.title": {
      "localizations": {
        "ar": {
