    "trend.detail.body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم هذا المخطط إدخالاتك المحلية لإظهار تغير الدرجات بمرور الوقت."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Diagramm nutzt deine lokalen Einträge, um Wertänderungen im Zeitverlauf zu zeigen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This chart uses your local entries to show score changes over time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este gráfico usa tus entradas locales para mostrar cambios de puntuación con el tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce graphique utilise vos entrées locales pour montrer l’évolution des scores dans le temps."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह चार्ट समय के साथ स्कोर बदलाव दिखाने के लिए आपकी स्थानीय प्रविष्टियों का उपयोग करता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Grafik ini menggunakan entri lokal Anda untuk menunjukkan perubahan skor dari waktu ke waktu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo grafico usa le tue voci locali per mostrare le variazioni dei punteggi nel tempo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このチャートはローカル記録を使って、時間経過によるスコア変化を示します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 차트는 로컬 기록을 사용해 시간에 따른 점수 변화를 보여줍니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este gráfico usa suas entradas locais para mostrar mudanças de pontuação ao longo do tempo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แผนภูมินี้ใช้รายการในเครื่องของคุณเพื่อแสดงการเปลี่ยนแปลงคะแนนตามเวลา"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu grafik, zaman içindeki puan değişikliklerini göstermek için yerel kayıtlarınızı kullanır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此图表使用你的本地记录显示评分随时间的变化。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此圖表使用你的本機記錄顯示評分隨時間的變化。"
          }
        }
      }
    },
