    "onboarding.welcome.detail": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يركز PeriMeno على تتبع ما قبل انقطاع الطمث وانقطاع الطمث، وليس تتبع الدورة العام."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno konzentriert sich auf Perimenopause- und Menopause-Tracking, nicht auf generisches Zyklustracking."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno focuses on perimenopause and menopause tracking, not generic cycle tracking."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno se centra en el seguimiento de perimenopausia y menopausia, no en un seguimiento genérico del ciclo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno se concentre sur le suivi de la périménopause et de la ménopause, pas sur un suivi générique du cycle."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno सामान्य चक्र ट्रैकिंग नहीं, बल्कि पेरिमेनोपॉज़ और मेनोपॉज़ ट्रैकिंग पर केंद्रित है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno berfokus pada pelacakan perimenopause dan menopause, bukan pelacakan siklus umum."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno si concentra sul monitoraggio di perimenopausa e menopausa, non sul ciclo generico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMenoは一般的な周期管理ではなく、ペリメノポーズと更年期の記録に焦点を当てています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno는 일반적인 주기 관리가 아니라 폐경이행기와 폐경 추적에 집중합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno foca no acompanhamento da perimenopausa e menopausa, não em um rastreador genérico de ciclo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno มุ่งเน้นการติดตามช่วงก่อนหมดประจำเดือนและวัยหมดประจำเดือน ไม่ใช่การติดตามรอบเดือนทั่วไป"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno genel döngü takibine değil perimenopoz ve menopoz takibine odaklanır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno 专注于围绝经期和更年期追踪，而不是普通周期追踪。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "PeriMeno 专注于围绝经期和更年期追踪，而不是普通周期追踪。"
          }
        }
      }
    },
