    "insights.lowData.averages": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضيفي إدخالين على الأقل لرؤية متوسط المزاج والنوم والطاقة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge mindestens zwei Einträge hinzu, um Durchschnittswerte für Stimmung, Schlaf und Energie zu sehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add at least two entries to see average mood, sleep, and energy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade al menos dos entradas para ver el promedio de ánimo, sueño y energía."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez au moins deux entrées pour voir les moyennes d’humeur, de sommeil et d’énergie."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मूड, नींद और ऊर्जा का औसत देखने के लिए कम से कम दो प्रविष्टियाँ जोड़ें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan setidaknya dua entri untuk melihat rata-rata suasana hati, tidur, dan energi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi almeno due voci per vedere la media di umore, sonno ed energia."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "気分、睡眠、エネルギーの平均を見るには少なくとも2件の記録を追加してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기분, 수면, 에너지 평균을 보려면 최소 두 개의 기록을 추가하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione pelo menos duas entradas para ver médias de humor, sono e energia."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพิ่มอย่างน้อยสองรายการเพื่อดูค่าเฉลี่ยอารมณ์ การนอน และพลังงาน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ortalama ruh hali, uyku ve enerjiyi görmek için en az iki kayıt ekleyin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "至少添加两条记录，才能查看情绪、睡眠和精力平均值。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "至少添加两条记录，才能查看情绪、睡眠和精力平均值。"
          }
        }
      }
    },
    "insights.lowData.symptoms": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سجلي الأعراض بمرور الوقت لمعرفة أيها يظهر غالبًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Protokolliere Symptome über die Zeit, um zu sehen, welches am häufigsten auftritt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log symptoms over time to see which one appears most often."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra síntomas con el tiempo para ver cuál aparece con más frecuencia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez les symptômes dans le temps pour voir lequel revient le plus souvent."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "समय के साथ लक्षण दर्ज करें ताकि सबसे बार आने वाला लक्षण दिखे।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Catat gejala dari waktu ke waktu untuk melihat mana yang paling sering muncul."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra i sintomi nel tempo per vedere quale compare più spesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "症状を継続して記録すると、最も多い症状が分かります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시간에 따라 증상을 기록하면 가장 자주 나타나는 증상을 볼 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre sintomas ao longo do tempo para ver qual aparece com mais frequência."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกอาการต่อเนื่องเพื่อดูว่าอาการใดเกิดขึ้นบ่อยที่สุด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "En sık hangisinin göründüğünü görmek için belirtileri zaman içinde kaydedin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "持续记录症状后，可以看到最常出现的症状。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "持续记录症状后，可以看到最常出现的症状。"
          }
        }
      }
    },
