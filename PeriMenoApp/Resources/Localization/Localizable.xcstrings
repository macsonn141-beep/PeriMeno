    "onboarding.premium.detail": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابدئي مجانًا. يضيف المميز تقارير أعمق وسجلًا أطول وأدوات تحضير متقدمة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kostenlos starten. Premium bietet tiefere Berichte, längeren Verlauf und erweiterte Vorbereitungstools."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start free. Premium adds deeper reports, longer history, and advanced preparation tools."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza gratis. Premium añade informes más profundos, historial más largo y herramientas avanzadas de preparación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez gratuitement. Premium ajoute des rapports plus détaillés, un historique plus long et des outils avancés de préparation."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मुफ़्त शुरू करें। प्रीमियम गहरी रिपोर्ट, लंबा इतिहास और उन्नत तैयारी टूल जोड़ता है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mulai gratis. Premium menambahkan laporan lebih dalam, riwayat lebih panjang, dan alat persiapan lanjutan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia gratis. Premium aggiunge report più approfonditi, cronologia più lunga e strumenti avanzati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "無料で開始。プレミアムでは詳細レポート、長い履歴、高度な準備ツールを利用できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "무료로 시작하세요. 프리미엄은 더 깊은 보고서, 더 긴 기록, 고급 준비 도구를 제공합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece grátis. O Premium adiciona relatórios mais profundos, histórico maior e ferramentas avançadas de preparação."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เริ่มฟรี พรีเมียมเพิ่มรายงานเชิงลึก ประวัติยาวขึ้น และเครื่องมือเตรียมขั้นสูง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ücretsiz başlayın. Premium daha derin raporlar, daha uzun geçmiş ve gelişmiş hazırlık araçları ekler."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先免费开始。高级版提供更深入报告、更长历史和高级准备工具。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "先免费开始。高级版提供更深入报告、更长历史和高级准备工具。"
          }
        }
      }
    },
