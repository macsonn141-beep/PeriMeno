    "reports.pdf.empty": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد سجلات في هذا النطاق الزمني بعد. أضيفي أو أنشئي سجلات عينة قبل إنشاء التقرير."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In diesem Datumsbereich gibt es noch keine Protokolle. Füge Einträge hinzu oder erstelle Beispieldaten, bevor du einen Bericht generierst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No logs in this date range yet. Add or seed sample logs before generating a report."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay registros en este rango de fechas. Añade o crea datos de muestra antes de generar un informe."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun journal dans cette plage de dates. Ajoutez ou générez des exemples avant de créer un rapport."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस तारीख़ सीमा में अभी कोई लॉग नहीं। रिपोर्ट बनाने से पहले लॉग जोड़ें या नमूना लॉग बनाएँ।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada catatan dalam rentang tanggal ini. Tambahkan atau buat data contoh sebelum membuat laporan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non ci sono ancora diari in questo intervallo. Aggiungi o genera dati di esempio prima di creare un report."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この期間にはまだ記録がありません。レポート生成前に記録を追加するかサンプルデータを作成してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 날짜 범위에는 아직 기록이 없습니다. 보고서를 생성하기 전에 기록을 추가하거나 샘플 기록을 만드세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há registros nesse intervalo. Adicione ou semeie registros de amostra antes de gerar um relatório."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังไม่มีบันทึกในช่วงวันที่นี้ เพิ่มหรือสร้างข้อมูลตัวอย่างก่อนสร้างรายงาน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu tarih aralığında henüz kayıt yok. Rapor oluşturmadan önce kayıt ekleyin veya örnek veri oluşturun."
          }
        },
        "zh-Hans": {
