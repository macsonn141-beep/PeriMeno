    "correlation.placeholder.lowSleepBrainFog": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ظهر النوم المنخفض وضباب الدماغ المرتفع معًا في الإدخالات:"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
