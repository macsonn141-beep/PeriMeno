    "report.disclaimer": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا التقرير للتتبع الشخصي ودعم النقاش. ليس تشخيصًا أو نصيحة طبية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Bericht dient dem persönlichen Tracking und der Unterstützung von Gesprächen. Er ist keine Diagnose und keine medizinische Beratung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This report is for personal tracking and discussion support. It is not a diagnosis or medical advice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este informe es para seguimiento personal y apoyo en conversaciones. No es un diagnóstico ni consejo médico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce rapport sert au suivi personnel et au soutien des échanges. Ce n’est ni un diagnostic ni un avis médical."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह रिपोर्ट व्यक्तिगत ट्रैकिंग और चर्चा समर्थन के लिए है। यह निदान या चिकित्सा सलाह नहीं है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Laporan ini untuk pelacakan pribadi dan dukungan diskusi. Ini bukan diagnosis atau saran medis."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo report serve al monitoraggio personale e al supporto della conversazione. Non è una diagnosi né un consiglio medico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このレポートは個人の記録と相談支援のためのものです。診断や医療助言ではありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보고서는 개인 기록과 상담 지원을 위한 것입니다. 진단이나 의학적 조언이 아닙니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Este relatório é para acompanhamento pessoal e apoio em conversas. Não é diagnóstico nem orientação médica."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รายงานนี้ใช้สำหรับติดตามส่วนตัวและช่วยสนับสนุนการพูดคุย ไม่ใช่การวินิจฉัยหรือคำแนะนำทางการแพทย์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu rapor kişisel takip ve görüşme desteği içindir. Tanı veya tıbbi tavsiye değildir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本报告仅用于个人追踪和辅助沟通，不是诊断或医疗建议。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本報告僅用於個人追蹤和輔助溝通，不是診斷或醫療建議。"
          }
        }
      }
    },
